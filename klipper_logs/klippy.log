gcode = 
	{% if 'S' in params %}
	{% if (params.S|float) > 300 %}
	M118 ;The nozzle setting temperature is out of limit and has been automatically adjusted to Limit the temperature.
	M118 ;热端设置温度超限，已经自动调整至限制温度。
	{% endif %}
	{% set TARGET = (params.S|float, 300)|min %}
